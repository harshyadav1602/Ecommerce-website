<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>

    <link rel="stylesheet" href="/CSS/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="page-shell">
        <div class="page-top">
            <div>
                <h1 class="hero-title">E-Store</h1>
                <p class="hero-subtitle">Your one-stop shop for all your needs.</p>
            </div>
            <a href="/new" class="btn btn-success btn-lg">Add New Product</a>
        </div>

        <div class="product-grid">
            <% for (let listing of listings) { %>
                <div class="card my-card shadow-sm">
                    <div class="card-img-frame">
                        <img src="<%= listing.image %>" class="card-img-top fixed-img" alt="<%= listing.title %>">
                        <div class="card-overlay">
                            <span class="badge badge-price">₹<%= listing.price || 'N/A' %></span>
                            <span class="badge badge-tag">Featured</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title"><%= listing.title %></h5>
                        <p class="product-meta"><%= listing.description ? listing.description.substring(0, 80) : 'A crisp new product to explore.' %></p>
                        <div class="card-labels">
                            <span class="label-pill">Details</span>
                            <span class="label-pill">Product</span>
                        </div>
                        <a href="/show/<%=listing._id%>" class="btn btn-primary btn-block">View Details</a>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
